# OpenAI Responses-compatible model endpoint used by the unified Agent runtime.
ARK_API_KEY=
ARK_BASE_URL=https://api.openai.com/v1
ARK_MODEL=

# Required to enable the persisted workspace APIs. The identity is configured on
# the server; requests cannot choose it through a client header.
FINANCE_GOD_DATABASE_URL=
FINANCE_GOD_WORKSPACE_OWNER_ID=

# Optional: required only by the deterministic FinRobot metrics adapter.
FMP_API_KEY=

# Optional: required only by PandaData monitor agents.
PANDA_DATA_USERNAME=
PANDA_DATA_PASSWORD=
PANDA_DATA_BASE_URL=
