# Copy to .env and set the key locally. .env is excluded from version control.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL=ep-20260722093003-7swj9

# Optional: FinRobot Equity runs in an isolated subprocess against FMP's current
# stable API. It never uses the model key.
FMP_API_KEY=

# Optional: fetch-only PandaData research. Activate data access with PandaAI first,
# then install `pip install -e '.[panda]'` and fill these local values.
# Format: 86 followed by the 11-digit PandaAI-registered phone number.
PANDA_DATA_USERNAME=86<registered_phone>
PANDA_DATA_PASSWORD=
PANDA_DATA_BASE_URL=
