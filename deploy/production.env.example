# 复制为 deploy/.env.production 并填写真实值。不要提交该生产文件。
APP_NAME=Finance-God
APP_ENV=production
APP_DEBUG=false
SQL_ECHO=false
CORS_ORIGINS=https://finance-god.example.com

POSTGRES_PASSWORD=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PandaData 是生产行情主源，用户名与密码均为必填。
PANDA_DATA_USERNAME=
PANDA_DATA_PASSWORD=
PANDA_DATA_BASE_URL=

# 至少配置一个生产文本提供方。
# DeepSeek 模型由管理端白名单配置；生产凭据在这里提供。
# DEEPSEEK_API_KEY=replace-with-production-key

# 或配置 StepFun；用户画像模型固定为 step-3.5-flash-2603。
# STEPFUN_API_KEY=replace-with-production-key

# 或配置 ARK；ARK 必须同时提供凭据与模型标识。
# ARK_API_KEY=replace-with-production-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=replace-with-production-model

VITE_WORKBENCH_ORIGIN=
WORKBENCH_ORIGIN=
