# ========== 数据库 ==========
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_god
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/finance_god

# ========== JWT ==========
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== LLM（开发默认 mock，无需真实 Key）==========
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-pro-32k
LLM_PROVIDER=mock

# ========== 数据源（开发默认 mock）==========
PANDAAI_API_KEY=your-pandaai-api-key
DATA_PROVIDER=mock

# ========== 应用 ==========
APP_NAME=Finance-God
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ========== 仿真账户 ==========
SIM_INITIAL_CASH=1000000
