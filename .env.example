# 复制为 .env 使用。此文件同时被 docker-compose 通过 env_file 读取。
# 数据库已统一：开发与生产均使用 PostgreSQL。本地先启动 postgres
#（docker compose up db 或本机实例）再执行 alembic upgrade head。

# ===== 应用 =====
APP_NAME=Finance-God
APP_ENV=development
APP_DEBUG=true
# 前端 dev 运行在 3000（Vite）。逗号分隔，不要留空格。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_god
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/finance_god
FINANCE_GOD_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/finance_god
# 可选：回显 SQLAlchemy SQL 语句（与 APP_DEBUG 解耦），仅本地调试时开启。
SQL_ECHO=false

# ===== JWT =====
# 工作区与仿真数据的唯一 owner 来自已验证 Bearer JWT 的 sub。
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 本地开发管理员（仅 development）=====
DEV_ADMIN_EMAIL=admin@finance-god.local
# 至少 12 位；不要提交真实密码。
DEV_ADMIN_PASSWORD=replace-with-a-strong-local-password

# ===== 研究运行时：OpenAI Responses 兼容端点（ARK / Doubao 等）=====
# 一旦配置 ARK_API_KEY 就不能留空；不使用 ARK 时保持注释。
# ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=

# ===== onboarding AI：DeepSeek（密钥仅后端读取）=====
# 地址固定为 https://api.deepseek.com，模型由管理端白名单选择。
# 注意：一旦取消注释就不能留空，否则启动即报错；未配置时开发环境走 mock 路径。
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ===== onboarding AI：StepFun（用户画像固定模型 step-3.5-flash-2603）=====
# 地址固定为 https://api.stepfun.com/v1；密钥仅由后端读取。
# STEPFUN_API_KEY=your-stepfun-api-key

# ===== 行情与指标数据源 =====
# PandaData：行情主源，仅后端持有凭据，浏览器永不接触。
PANDA_DATA_USERNAME=
PANDA_DATA_PASSWORD=
PANDA_DATA_BASE_URL=
# 可选：确定性 FinRobot 指标适配器需要。
FMP_API_KEY=
# 可选：Alpha Vantage 备用指标源。
ALPHA_VANTAGE_API_KEY=

# ===== 前端浏览器交接目标 =====
# 外部工作台的精确 http/https origin。
VITE_WORKBENCH_ORIGIN=
# 兼容别名；仅在 VITE_WORKBENCH_ORIGIN 未设置时使用。
WORKBENCH_ORIGIN=
