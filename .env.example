# ========== 数据库 ==========
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_god
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/finance_god

# ========== JWT ==========
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== AI（密钥仅由后端读取）==========
DEEPSEEK_API_KEY=your-deepseek-api-key
# DeepSeek 地址固定为 https://api.deepseek.com，模型由管理端白名单选择。

# ========== 应用 ==========
APP_NAME=Finance-God
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEV_ADMIN_EMAIL=admin@finance-god.local
# 仅限 development，至少 12 位；不要提交真实密码。
DEV_ADMIN_PASSWORD=replace-with-a-strong-local-password
# 浏览器交接目标，需填写外部工作台的精确 http/https origin
VITE_WORKBENCH_ORIGIN=
# 兼容别名；仅在 VITE_WORKBENCH_ORIGIN 未设置时使用
WORKBENCH_ORIGIN=
